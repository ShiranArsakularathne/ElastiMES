# Local SQLite Database (for touch panel)
# Use /app/data/local_mes.db in Docker, or local_mes.db for local development
SQLITE_PATH=/app/data/local_mes.db

# Central SQL Server Database (for synchronization)
SQL_SERVER_HOST=
SQL_SERVER_DATABASE=
SQL_SERVER_USER=
SQL_SERVER_PASSWORD=
SQL_SERVER_DRIVER=ODBC Driver 17 for SQL Server
SQL_SERVER_ENCRYPT=false

# Sync settings
SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=20

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# SQL API (legacy)
API_KEY_HASH=replace_with_sha256_of_api_key
ALLOWED_SERVERS=
RATE_LIMIT_PER_MINUTE=60
ENCRYPT=false

# Security (for JWT if implemented later)
SECRET_KEY=change_this_to_a_secure_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ERP API Configuration
ERP_API_URL=https://api.example.com/erp
ERP_API_KEY=test_api_key
ERP_API_TIMEOUT=30

# PLC Configuration
PLC_HOST=192.168.1.100
PLC_PORT=502
PLC_UNIT_ID=1
PLC_POLL_INTERVAL=5

# Barcode Scanner Configuration
BARCODE_SCANNER_PORT=/dev/ttyUSB0
BARCODE_SCANNER_BAUDRATE=9600

# RFID Reader Configuration
RFID_READER_HOST=192.168.1.101
RFID_READER_PORT=10001
